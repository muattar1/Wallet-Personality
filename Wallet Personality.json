    {
      "parameters": {
        "jsCode": "const text = $input.all()[0].json.content.parts[0].text;\n\n// Regex use kar ke specific parts nikal rahe hain\nconst personalityMatch = text.match(/\\*\\*Personality:\\*\\*\\s*\\*\\*(.*?)\\*\\*/);\nconst riskScoreMatch = text.match(/\\*\\*Risk Score:\\*\\*\\s*\\*\\*(.*?)\\*\\*/);\n\n// Summary nikalne ke liye Hinglish section ko target kar rahe hain\nconst summaryLines = text.split('---')[1] || \"\";\nconst cleanSummary = summaryLines.replace(/\\*\\*Creative Summary \\(Hinglish\\/Urdu\\):\\*\\*/, \"\").trim();\n\nreturn {\n  personality: personalityMatch ? personalityMatch[1] : \"Unknown\",\n  riskScore: riskScoreMatch ? riskScoreMatch[1] : \"N/A\",\n  hinglishSummary: cleanSummary\n};"
      },
