    {
      "parameters": {
        "jsCode": "const items = $input.all();\nlet transactions = [];\n\nif (items.length > 0 && items[0].json.result && items[0].json.result.transfers) {\n  transactions = items[0].json.result.transfers;\n}\n\nconst simplifiedData = transactions.slice(0, 15).map(tx => ({\n    asset: tx.asset,\n    value: tx.value,\n    to: tx.to,\n    time: tx.metadata ? tx.metadata.blockTimestamp : 'N/A', // Time add kar diya\n    category: tx.category\n}));\n\nreturn {\n  geminiInput: JSON.stringify(simplifiedData),\n  totalFound: transactions.length\n};"
      },
